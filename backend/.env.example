# Paperorg Notes Pro Backend
PAPERORG_JWT_SECRET=change-me-to-a-long-random-string
PAPERORG_DEV_MODE=true

# Provider keys (server-side only — never ship to the app)
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
LUXASR_API_KEY=

# Pro plan limits
PRO_MINUTES_PER_MONTH=600
FREE_VOCABULARY_LIMIT=20

# Optional: App Store Server API (production subscription verification)
APPLE_BUNDLE_ID=com.paperorg.notes
APPLE_PRO_PRODUCT_ID=com.paperorg.notes.pro.monthly
