# Paperorg Notes Pro Backend
PAPERORG_JWT_SECRET=change-me-to-a-long-random-string
PAPERORG_DEV_MODE=true

# Database: leave empty for local SQLite, or set PostgreSQL in production
# DATABASE_URL=postgresql://paperorg:paperorg@127.0.0.1:5444/paperorg_pro

# Provider keys (server-side only — never ship to the app)
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
LUXASR_API_KEY=

# Pro plan limits
PRO_MINUTES_PER_MONTH=600
FREE_VOCABULARY_LIMIT=20

# Optional: App Store Server API (production subscription verification)
APPLE_BUNDLE_ID=com.paperorg.notes
APPLE_PRO_PRODUCT_ID=com.paperorg.notes.pro.monthly
APPLE_ISSUER_ID=
APPLE_KEY_ID=
# Path to AuthKey_XXXX.p8 or paste PEM contents
APPLE_PRIVATE_KEY=
# Optional: Paperorg Platform (Phase C/D)
# PLATFORM_API_URL=https://poplatform.paperorg.com
# PLATFORM_INTERNAL_TOKEN=...

# Optional: local email fallback for dev (production should use Platform email relay)
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USERNAME=
# EMAIL_SMTP_PASSWORD=
# EMAIL_FROM_ADDRESS=notes@paperorg.com
# EMAIL_FROM_NAME=Paperorg Notes
# EMAIL_DAILY_LIMIT=50
