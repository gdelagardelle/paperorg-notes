    "privacy.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Privacy Matters"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre vie privée compte"
          }
