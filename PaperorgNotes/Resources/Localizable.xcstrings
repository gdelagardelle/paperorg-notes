    "privacy.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paperorg Notes records audio on your device. On the Free plan, transcription uses your own OpenAI and ElevenLabs keys. Paperorg Pro includes cloud transcription with no keys required."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paperorg Notes enregistre l'audio sur votre appareil. Avec l'offre gratuite, la transcription utilise vos propres clés OpenAI et ElevenLabs. Paperorg Pro inclut la transcription cloud sans clés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Paperorg Notes zeichnet Audio auf Ihrem Gerät auf. Im Free-Plan nutzt die Transkription Ihre eigenen OpenAI- und ElevenLabs-Schlüssel. Paperorg Pro enthält Cloud-Transkription ohne Schlüssel."
          }
        }
      }
    },
    "privacy.agree": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand and agree to the Privacy Policy"
